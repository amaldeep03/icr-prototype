OPENAI_API_KEY=your_key_here

# Comma-separated list of allowed CORS origins for the backend
# Example: http://localhost:5173,http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# (Optional) Port the backend should listen on when run locally
PORT=8000

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
# Set LANGCHAIN_API_KEY to enable tracing. All OpenAI calls (vision passes,
# classification, illustration parsing) and every LangGraph node will appear
# in the LangSmith dashboard with token counts and cost estimates.
# Get your key at: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=icr-prototype
